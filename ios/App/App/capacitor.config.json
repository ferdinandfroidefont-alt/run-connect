{
	"appId": "com.ferdi.runconnect",
	"appName": "RunConnect",
	"webDir": "dist",
	"bundledWebRuntime": false,
	"plugins": {
		"PushNotifications": {
			"presentationOptions": [
				"badge",
				"sound",
				"alert"
			]
		},
		"Geolocation": {},
		"Camera": {},
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#0066CC"
		},
		"Keyboard": {
			"resize": "native",
			"resizeOnFullScreen": true
		}
	},
	"android": {
		"allowMixedContent": false,
		"captureInput": true,
		"webContentsDebuggingEnabled": false,
		"allowMultipleWindows": false,
		"useLegacyBridge": false,
		"deepLinkScheme": "app.runconnect",
		"appendUserAgent": "RunConnect/1.3"
	},
	"ios": {
		"contentInset": "never",
		"allowsLinkPreview": false,
		"scrollEnabled": true,
		"preferredContentMode": "mobile",
		"limitsNavigationsToAppBoundDomains": false,
		"scheme": "runconnect",
		"backgroundColor": "#0066CC",
		"appendUserAgent": "RunConnect-iOS/1.3"
	},
	"packageClassList": [
		"AdMobPlugin",
		"ContactsPlugin",
		"AppPlugin",
		"CAPBrowserPlugin",
		"CAPCameraPlugin",
		"DevicePlugin",
		"FilesystemPlugin",
		"GeolocationPlugin",
		"HapticsPlugin",
		"InAppBrowserPlugin",
		"KeyboardPlugin",
		"PushNotificationsPlugin",
		"SharePlugin",
		"StatusBarPlugin"
	]
}
