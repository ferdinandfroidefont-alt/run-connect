# Exemple — copier vers .env (ne pas commiter .env avec secrets)
# Obligatoires pour le client (Settings → API dans Supabase)
# VITE_SUPABASE_URL=https://VOTRE_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=collier_la_cle_anon_publique

# Email affiché dans CGU / confidentialité (non secret — support & stores)
# VITE_PUBLIC_SUPPORT_EMAIL=contact@votredomaine.com

# Mentions légales (optionnel — sinon placeholders dans l’app)
# VITE_PUBLIC_LEGAL_ENTITY_NAME=RunConnect SAS
# VITE_PUBLIC_LEGAL_ADDRESS=12 rue Exemple|75001 Paris|France
# VITE_PUBLIC_LEGAL_SIRET=
# VITE_PUBLIC_LEGAL_RCS=
# VITE_PUBLIC_LEGAL_DIRECTOR=
# VITE_PUBLIC_LEGAL_HOSTING=Supabase Inc. — …

# Mapbox (carte principale — token public « default » côté client, restreins par URL dans Mapbox)
# VITE_MAPBOX_ACCESS_TOKEN=COLLER_ICI_MON_TOKEN_MAPBOX

# Analytics (optionnel) — voir docs/LAUNCH_OPTIMIZATION.md
# VITE_ANALYTICS_DEBUG=true
# VITE_ANALYTICS_ENABLED=false

# Logs debug dans le WebView (bandeau bas) — utile sur mobile sans adb
# true = toujours | native = shell Capacitor uniquement | false = désactivé (prod store)
# En dev, activé par défaut sauf si VITE_DEBUG_ON_SCREEN=false
# VITE_DEBUG_ON_SCREEN=native

# AdMob public IDs (optionnel en dev: des IDs de test Google sont utilisés par défaut)
# VITE_ADMOB_APP_ID_ANDROID=ca-app-pub-xxxxxxxx~xxxxxxxxxx
# VITE_ADMOB_APP_ID_IOS=ca-app-pub-xxxxxxxx~xxxxxxxxxx
# VITE_ADMOB_REWARDED_ANDROID_ID=ca-app-pub-xxxxxxxx/xxxxxxxxxx
# VITE_ADMOB_REWARDED_IOS_ID=ca-app-pub-xxxxxxxx/xxxxxxxxxx
